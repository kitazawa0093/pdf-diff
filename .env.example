# 購入・Pro 版（配布ビルド時）
# VITE_PRO_PASSWORD=your-pro-password  # 配布用。開発は .env.local
# VITE_BOOTH_URL=https://your-shop.booth.pm/items/xxxx

# Web 版に「ダウンロード版はこちら」（未設定なら非表示。有料 URL 未設定時は BOOTH URL を使用）
# VITE_PAID_DOWNLOAD_LABEL=有料ダウンロード版はこちら
# VITE_PAID_DOWNLOAD_URL=https://your-shop.booth.pm/items/xxxx
# VITE_FREE_DOWNLOAD_URL=https://github.com/you/pdf-diff/releases
# VITE_FREE_DOWNLOAD_LABEL=無料PC版をダウンロード（3ページまで）
# VITE_PAID_DOWNLOAD_LABEL=有料PC版はこちら（全ページ・BOOTH）

# GitHub Pages 用（リポジトリ名が pdf-diff なら /pdf-diff/）
# VITE_BASE_PATH=/pdf-diff/

# デスクトップ版ツールバーに「Web版」リンク
# VITE_WEB_APP_URL=https://あなた.github.io/pdf-diff/

# 「開発承ります」フッター（どちらか一方で可）
# VITE_COMMISSION_LABEL=開発のご相談を承ります
# VITE_CONTACT_EMAIL=you@example.com
# VITE_COMMISSION_URL=https://forms.google.com/...
